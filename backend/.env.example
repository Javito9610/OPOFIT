# =================================================================
#   OpoFit Backend — variables de entorno
# =================================================================
#   Copia este fichero a .env y rellena los valores.
#   .env NO debe subirse al repo (ya está en .gitignore).
# =================================================================

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- Base de datos MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=opofit
DB_PASS=cambia_esto
DB_NAME=opofit
DB_POOL_SIZE=15
# Si Cloud SQL / Railway exigen TLS:
DB_SSL=false

# --- JWT (OBLIGATORIO) ---
# Sin esta variable la app NO arranca correctamente. Genera con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secret_random_de_al_menos_48_bytes

# --- Rate limiting ---
RATE_LIMIT_GLOBAL=1200
RATE_LIMIT_AUTH=30

# =================================================================
#   IA / LLM — Coach de planes de entrenamiento (OPCIONAL)
# =================================================================
# Si no defines ninguna, la app usa fallback por reglas (siempre
# funciona, pero los planes son menos personalizados).
#
# Orden de preferencia EN ESTE BACKEND:
#   1. Groq (Llama 3.3)    → GRATIS, sin tarjeta. RECOMENDADO para empezar.
#   2. Claude (Anthropic)  → MEJOR calidad para prompt v14 científico (pago)
#   3. OpenAI              → Buena alternativa (pago)
#   4. Gemini              → Más económico, calidad menor en JSON
#
# Activa SOLO UNA, la primera disponible se usa.
# -----------------------------------------------------------------

# --- Groq (GRATIS — RECOMENDADO) ---
# Console: https://console.groq.com  (registro con email, sin tarjeta)
# Tier free 2025: ~14.400 requests/día con Llama 3.3 70B.
# Hardware LPU: 5-10x más rápido que OpenAI/Claude.
# Una sesión completa = ~1500 tokens → SOBRA con free tier para una app
# personal o un MVP con cientos de usuarios.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic Claude (recomendado para producción) ---
# Console: https://console.anthropic.com
# Modelo recomendado: claude-3-5-sonnet (balance calidad/precio).
# Coste aprox 2026: $3 / 1M input, $15 / 1M output tokens.
# Una sesión completa = ~3000 tokens → ~$0.01-0.02 por usuario/semana.
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# --- OpenAI ---
# Console: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
# Console: https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# =================================================================
#   Crons / scheduled jobs
# =================================================================
NOTIFICATIONS_CRON=true
NOTICIAS_CRON_DISABLED=false

# =================================================================
#   Integraciones de relojes / fitness
# =================================================================
# OAuth callbacks. Si están vacíos, el botón en la app responde 503.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
POLAR_REDIRECT_URI=

# Mapas (Overpass es público, no necesita key).
MAPS_API_KEY=
