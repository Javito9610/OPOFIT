# === Configuración del Servidor ===
PORT=3000

# === Base de Datos MySQL ===
DB_HOST=localhost
DB_USER=root
DB_PASS=tu_contraseña
DB_NAME=mydb

# === JWT (JSON Web Token) ===
# Clave secreta para firmar los tokens. Usa una cadena larga y aleatoria.
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_clave_secreta_aqui

# === Google OAuth ===
# Client ID de Google para verificar tokens de inicio de sesión con Google.
# Obténlo en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
